img{
    max-width: 100%;
}

h2{
    color:rgb(255, 0, 0);
}

.container{
    width: 1000px;
    margin-left: auto;
    margin-right: auto;
    display: flex;
}

.container .image{
    width: 30%;
}

.container .content{
    float:right ;width: 70%;
    margin: 80px 25px 0px 25px;
}

.container a{
    color: black;
    text-decoration: none;
    border-bottom: 2px solid #cccccc;
    padding-bottom: 5px;
}

.container a:hover{
    border-bottom: 2px #000000;
}

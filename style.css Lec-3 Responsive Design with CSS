img{
    max-width: 100%;
}

h2{
    color:rgb(255, 0, 0);
}

.container{
    width: 1000px;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    display: flex;
}

.container .image{
    width: 30%;
}

.container .content{
    float:right ;width: 70%;
    margin: 80px 25px 0px 25px;
}

.container a{
    color: black;
    text-decoration: none;
    border-bottom: 2px solid #cccccc;
    padding-bottom: 5px;
}

.container a:hover{
    border-bottom: 2px #000000;
}

@media print{
    a{
        display: none;
    }
    
}

@media screen and (max-width: 420pcx) {
    
}

@media screen and (max-width: 600px) {

.container{
    flex-direction: column-reverse;
}

.container .content{
    margin-top: 20px;
    width: 100%;
    margin-left: 0;
    margin-right: 0;
    padding: 0 25px
}

.container .image{
    margin:0 25px
}

}
